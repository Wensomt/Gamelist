        "/api/profile/password": {
            "patch": {
                "tags": [
                    "Profile"
                ],
                "summary": "Zmień hasło użytkownika (API)",
                "operationId": "1f3f863d7ca679ebc890de0fd701d3b4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "current_password",
                                    "new_password"
                                ],
                                "properties": {
                                    "current_password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "old_password123"
                                    },
                                    "new_password": {
                                        "type": "string",
                                        "format": "password",
                                        "minLength": 8,
                                        "example": "new_password456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Hasło zostało zmienione",
                        "content": {
