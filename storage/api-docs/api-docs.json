                    "404": {
                        "description": "Użytkownik nie znaleziony"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Admin"
                ],
                "summary": "Usuń użytkownika (API)",
                "description": "Usuwanie użytkownika - DODANO ZABEZPIECZENIE",
                "operationId": "e969a694748f958b5ee2e183805457e4",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID użytkownika do usunięcia",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Użytkownik usunięty",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Użytkownik usunięty."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Brak uprawnień lub próba usunięcia własnego konta"
                    },
                    "404": {
                        "description": "Użytkownik nie znaleziony"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Admin"
                ],
                "summary": "Zaktualizuj dane użytkownika (API)",
                "operationId": "0a67e28c83dc3da8b37c0e54186ff67b",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID użytkownika",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Nowa Nazwa"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "nowy@email.com"
                                    },
                                    "is_admin": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
